{
  "name": "interactive-globey-maplibre",
  "version": "0.1.5",
  "description": "A MapLibre globe scrollyteller and builder",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/abcnews/interactive-globey-maplibre.git"
  },
  "bugs": {
    "url": "https://github.com/abcnews/interactive-globey-maplibre/issues"
  },
  "homepage": "https://github.com/abcnews/interactive-globey-maplibre#readme",
  "contributors": [
    "Ash Kyd <kyd.ashley@abc.net.au>"
  ],
  "scripts": {
    "dev": "vite dev",
    "build": "vite build && npm run prepack",
    "deploy": "npm run build && node deploy/index.js",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "prepack": "svelte-kit sync && svelte-package && publint",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "prettier --check .",
    "format": "prettier --write .",
    "test": "vitest run",
    "patch-style": "node src/components/CustomGlobe/mapStyle/node_patchStyleFromBen.js"
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "!dist/**/*.spec.*"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "svelte": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js"
    }
  },
  "peerDependencies": {
    "svelte": "^5.0.0"
  },
  "devDependencies": {
    "@abcnews/alternating-case-to-object": "^3.2.0",
    "@abcnews/base-36-text": "^1.0.1",
    "@abcnews/components-storylab": "^0.0.2",
    "@abcnews/env-utils": "^6.0.0",
    "@abcnews/hash-codec": "^2.0.0",
    "@abcnews/mount-utils": "^3.0.0",
    "@abcnews/palette": "^1.0.1",
    "@abcnews/svelte-scrollyteller": "^3.0.1",
    "@sveltejs/adapter-auto": "^7.0.0",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.50.2",
    "@sveltejs/package": "^2.5.7",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@types/topojson-client": "^3.1.5",
    "async": "^3.2.6",
    "basic-ftp": "^5.1.0",
    "canvas": "^2.11.2",
    "compression-streams-polyfill": "^0.1.7",
    "d3-geo": "^3.1.1",
    "geotiff": "^3.0.0",
    "latlon-geohash": "^2.0.0",
    "layercake": "^10.0.2",
    "maplibre-gl": "^5.16.0",
    "marked": "^17.0.1",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.4.1",
    "publint": "^0.3.17",
    "sass-embedded": "^1.97.3",
    "sharp": "^0.34.5",
    "svelte": "^5.49.2",
    "svelte-bootstrap-icons": "^3.3.0",
    "svelte-check": "^4.3.6",
    "three": "^0.182.0",
    "throttle-debounce": "^5.0.2",
    "topojson-client": "^3.1.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "keywords": [
    "svelte"
  ],
  "dependencies": {
    "@abcnews/components-builder": "^0.0.19"
  }
}
